# AI Journal Maker - Environment Variables

# OpenRouter API Key (default - access to 100+ AI models)
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Alternative: Google Gemini API Key
# GOOGLE_API_KEY=your-google-api-key-here

# Alternative: OpenAI API Key
# OPENAI_API_KEY=your-openai-api-key-here

# Cloudinary URL (for production image storage)
# Get from https://cloudinary.com
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Database URL (auto-set by Railway in production)
# DATABASE_URL=postgresql://user:password@host:port/database

# Server Port (Railway auto-sets this)
PORT=8000
